---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const others = allPosts.filter((p) => p.id !== post.id).slice(0, 2);
---
<Layout title={`${post.data.title} — Кирилл Барыев`} description={post.data.description}>
  <Nav />
  <article class="post">
    <div class="container-x">
      <a href={`${base}/blog/`} class="post__back" data-hover>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Все заметки
      </a>

      <header class="post__head">
        <div class="post__meta">
          <span>{formatDate(post.data.date)}</span>
          {post.data.readTime && <><span class="post__sep">·</span><span>{post.data.readTime}</span></>}
        </div>
        <h1 class="post__title">{post.data.title}</h1>
        <p class="post__lead">{post.data.description}</p>
        <div class="post__tags">
          {post.data.tags.map((t) => <span class="post-tag">{t}</span>)}
        </div>
      </header>

      {post.data.tldr && (
        <aside class="post__tldr">
          <div class="post__tldr-label">TL;DR</div>
          <p>{post.data.tldr}</p>
        </aside>
      )}

      <div class="post__body">
        <Content />
      </div>

      <footer class="post__footer">
        <div class="post__footer-cta">
          <h3>Понравилась заметка?</h3>
          <p>Напишите мне — расскажу про такое лично, подскажу под вашу задачу.</p>
          <a href="https://t.me/tori2k" target="_blank" rel="noopener" class="btn btn--filled">
            <span class="btn__plus">(+)</span>
            Написать в Telegram
          </a>
        </div>

        {others.length > 0 && (
          <div class="post__others">
            <div class="post__others-title">Ещё заметки</div>
            <div class="post__others-grid">
              {others.map((p) => (
                <a href={`${base}/blog/${p.id}/`} class="post__other-card" data-hover>
                  <div class="post__other-date">{formatDate(p.data.date)}</div>
                  <div class="post__other-title">{p.data.title}</div>
                </a>
              ))}
            </div>
          </div>
        )}
      </footer>
    </div>
  </article>
  <Footer />
</Layout>

<style is:global>
  .post {
    padding: 120px 0 80px;
    background: var(--color-bg);
  }
  .post .container-x { max-width: 780px; }

  .post__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    padding-bottom: 20px;
    transition: color 0.2s;
  }
  .post__back:hover { color: var(--color-accent); }

  .post__head {
    padding: 40px 0 32px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 40px;
  }
  .post__meta {
    display: flex;
    gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--color-muted-2);
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .post__sep { color: var(--color-accent); }

  .post__title {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 0 0 20px;
    color: var(--color-text);
  }
  .post__lead {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0 0 20px;
  }
  .post__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  /* TLDR */
  .post__tldr {
    padding: 20px 24px;
    background: rgba(212,255,60,0.05);
    border-left: 2px solid var(--color-accent);
    border-radius: 2px;
    margin-bottom: 40px;
  }
  .post__tldr-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .post__tldr p {
    font-size: 14.5px;
    color: var(--color-text);
    line-height: 1.65;
    margin: 0;
  }

  /* Body prose */
  .post__body {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text);
  }
  .post__body h2 {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(22px, 2vw, 30px);
    font-weight: 500;
    margin: 50px 0 18px;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .post__body h3 {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(17px, 1.5vw, 21px);
    font-weight: 500;
    margin: 32px 0 12px;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .post__body p {
    margin: 0 0 18px;
    color: var(--color-text);
  }
  .post__body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .post__body strong { color: var(--color-text); font-weight: 600; }
  .post__body em { color: var(--color-muted); font-style: italic; }
  .post__body ul, .post__body ol {
    margin: 0 0 18px;
    padding-left: 22px;
    color: var(--color-text);
  }
  .post__body li { margin-bottom: 8px; }
  .post__body code:not(pre code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    background: var(--color-surface);
    padding: 2px 6px;
    border-radius: 3px;
    border: 1px solid var(--color-border);
    color: var(--color-accent);
  }
  .post__body pre {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 20px 24px;
    border-radius: 4px;
    overflow-x: auto;
    margin: 0 0 24px;
    font-size: 13.5px;
    line-height: 1.6;
  }
  .post__body pre code {
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-text);
  }
  .post__body table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 24px;
    font-size: 14px;
  }
  .post__body table th, .post__body table td {
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .post__body table th {
    background: var(--color-surface);
    font-weight: 500;
    font-family: 'Unbounded', sans-serif;
    font-size: 12px;
    letter-spacing: 0.5px;
  }
  .post__body hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }
  .post__body blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 20px;
    margin: 0 0 20px;
    font-style: italic;
    color: var(--color-muted);
  }

  /* Footer */
  .post__footer {
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--color-border);
  }
  .post__footer-cta {
    padding: 40px;
    background: linear-gradient(135deg, rgba(212,255,60,0.06), rgba(212,255,60,0));
    border: 1px solid rgba(212,255,60,0.25);
    border-radius: 4px;
    text-align: center;
    margin-bottom: 50px;
  }
  .post__footer-cta h3 {
    font-family: 'Unbounded', sans-serif;
    font-size: 22px;
    font-weight: 500;
    margin: 0 0 8px;
    color: var(--color-text);
  }
  .post__footer-cta p {
    font-size: 14px;
    color: var(--color-muted);
    margin: 0 0 24px;
  }

  .post__others-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .post__others-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .post__other-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    text-decoration: none;
    transition: all 0.3s;
  }
  .post__other-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .post__other-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--color-muted-2);
    text-transform: uppercase;
  }
  .post__other-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-text);
  }

  @media (max-width: 700px) {
    .post { padding: 100px 0 60px; }
    .post__others-grid { grid-template-columns: 1fr; }
    .post__footer-cta { padding: 28px 20px; }
  }
</style>
