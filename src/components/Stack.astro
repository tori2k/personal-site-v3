---
const tech = [
  { name: 'Astro', role: 'Фреймворк' },
  { name: 'TypeScript', role: 'Типизация' },
  { name: 'Tailwind', role: 'Стили' },
  { name: 'MDX', role: 'Контент' },
  { name: 'GitHub Pages', role: 'Хостинг' },
  { name: 'Cloudflare', role: 'DNS' },
  { name: 'Т-Касса', role: 'Оплаты' },
  { name: 'Google Sheets', role: 'Админка' },
  { name: 'Timepad', role: 'Билеты' },
];
---
<section class="stack" id="stack">
  <div class="container-x">
    <div class="stack__grid">
      <div class="stack__left reveal-left">
        <div class="sec-tag">Как это устроено</div>
        <h2 class="display-h stack__title">
          Просто — <em>и</em><br/>
          надёжно
        </h2>
        <p class="stack__lead">
          Объясняю своими словами, почему такой сайт служит годами и&nbsp;не&nbsp;требует от&nbsp;вас ежемесячных платежей.
        </p>

        <ul class="stack__benefits">
          <li>
            <span class="stack__b-n">01</span>
            <div>
              <div class="stack__b-t">Бесплатный хостинг навсегда</div>
              <div class="stack__b-d">Сайт лежит на серверах GitHub. Не нужно платить ни за хостинг, ни за конструктор — только за домен (≈200&nbsp;₽ в&nbsp;год).</div>
            </div>
          </li>
          <li>
            <span class="stack__b-n">02</span>
            <div>
              <div class="stack__b-t">Открывается за секунду</div>
              <div class="stack__b-d">Посетитель не уходит из-за долгой загрузки — страница появляется сразу, даже на слабом интернете.</div>
            </div>
          </li>
          <li>
            <span class="stack__b-n">03</span>
            <div>
              <div class="stack__b-t">Сайт принадлежит вам</div>
              <div class="stack__b-d">Никаких подписок и&nbsp;рисков, что сервис закроется. Исходники сайта передаю вам — можно переехать куда угодно.</div>
            </div>
          </li>
        </ul>

        <details class="stack__details">
          <summary>Для тех, кому интересны технологии</summary>
          <div class="stack__tech">
            {tech.map((t) => (
              <div class="tchip">
                <span class="tchip__name">{t.name}</span>
                <span class="tchip__role">{t.role}</span>
              </div>
            ))}
          </div>
        </details>
      </div>

      <aside class="stack__right reveal-right">
        <figure class="quote">
          <div class="quote__mark">&ldquo;</div>
          <blockquote>
            Сайт должен работать на&nbsp;владельца, а&nbsp;не&nbsp;наоборот:
            приносить заявки, принимать оплаты, не&nbsp;требовать обслуживания.
          </blockquote>
          <figcaption>
            <span class="quote__name">Кирилл Барыев</span>
            <span class="quote__role">Разработчик</span>
          </figcaption>
        </figure>

        <div class="numbers">
          <div class="num">
            <div class="num__n">~200 ₽</div>
            <div class="num__l">в год за домен — единственный регулярный платёж</div>
          </div>
          <div class="num">
            <div class="num__n">0 ₽</div>
            <div class="num__l">за хостинг, конструктор, подписки</div>
          </div>
          <div class="num">
            <div class="num__n">&lt; 1 с</div>
            <div class="num__l">средняя скорость загрузки на 4G</div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .stack { padding: 140px 0; }
  .stack__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .stack__title { margin: 0 0 24px; }
  .stack__lead {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0 0 40px;
    max-width: 480px;
  }

  .stack__benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .stack__benefits li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    align-items: start;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
  }
  .stack__benefits li:last-child { border-bottom: none; padding-bottom: 0; }
  .stack__b-n {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--color-muted);
    padding-top: 4px;
  }
  .stack__b-t {
    font-family: 'Unbounded', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .stack__b-d {
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .stack__details {
    margin-top: 8px;
  }
  .stack__details summary {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
    cursor: pointer;
    padding: 12px 0;
    border-top: 1px solid var(--color-border);
    list-style: none;
    transition: color 0.2s;
  }
  .stack__details summary::-webkit-details-marker { display: none; }
  .stack__details summary::before {
    content: '+ ';
    color: var(--color-text);
  }
  .stack__details[open] summary::before { content: '− '; }
  .stack__details summary:hover { color: var(--color-text); }
  .stack__details .stack__tech { margin-top: 16px; }

  .stack__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tchip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    background: transparent;
    border: 1px solid var(--color-border-2);
    border-radius: 999px;
    transition: all 0.3s;
  }
  .tchip:hover {
    border-color: var(--color-text);
  }
  .tchip__name {
    font-family: 'Unbounded', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text);
  }
  .tchip__role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* Quote card */
  .quote {
    position: relative;
    padding: 48px 40px 40px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    margin: 0 0 20px;
  }
  .quote__mark {
    position: absolute;
    top: 12px;
    left: 28px;
    font-family: 'Unbounded', sans-serif;
    font-size: 120px;
    line-height: 1;
    color: var(--color-text);
    opacity: 0.12;
    pointer-events: none;
  }
  .quote blockquote {
    margin: 0 0 28px;
    font-family: 'Unbounded', sans-serif;
    font-weight: 400;
    font-size: clamp(20px, 1.7vw, 24px);
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .quote figcaption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }
  .quote__name {
    font-family: 'Unbounded', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
  }
  .quote__role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* Numbers */
  .numbers {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }
  .num {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 20px;
    align-items: baseline;
    padding: 22px 4px;
    border-bottom: 1px solid var(--color-border);
  }
  .num__n {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
    white-space: nowrap;
  }
  .num__l {
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .stack { padding: 80px 0; }
    .stack__grid { grid-template-columns: 1fr; gap: 40px; }
    .quote { padding: 40px 28px 32px; }
  }
</style>
