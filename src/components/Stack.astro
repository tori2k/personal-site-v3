---
const tech = [
  { name: 'Astro', role: 'Фреймворк', color: '#FF5D01' },
  { name: 'TypeScript', role: 'Типизация', color: '#3178C6' },
  { name: 'Tailwind v4', role: 'Стили', color: '#38BDF8' },
  { name: 'MDX', role: 'Контент', color: '#f1f1f1' },
  { name: 'GitHub Pages', role: 'Хостинг', color: '#f1f1f1' },
  { name: 'Cloudflare', role: 'DNS', color: '#F38020' },
  { name: 'Т-Касса', role: 'Оплаты', color: '#FFDD2D' },
  { name: 'Google Sheets', role: 'Админка', color: '#0F9D58' },
  { name: 'Timepad', role: 'Билеты', color: '#0E76A8' },
];
---
<section class="stack section-dark" id="stack">
  <div class="container-x">
    <div class="stack__grid">
      <div class="stack__left reveal-left">
        <div class="sec-tag">Что умею</div>
        <h2 class="display-h stack__title">
          Стек — <em>простой</em><br/>
          и надёжный
        </h2>
        <p class="stack__lead">
          Только проверенное. Никаких «революционных» технологий, которые
          сломаются через год. Astro + Tailwind живут десятилетиями
          и работают быстро без магии.
        </p>

        <div class="stack__tech">
          {tech.map((t) => (
            <div class="tchip" style={`--tc: ${t.color}`}>
              <span class="tchip__dot"></span>
              <span class="tchip__name">{t.name}</span>
              <span class="tchip__role">{t.role}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="stack__right reveal-right">
        <div class="terminal">
          <div class="terminal__bar">
            <div class="terminal__dots">
              <span></span><span></span><span></span>
            </div>
            <div class="terminal__title">zsh — ~/projects/your-site</div>
          </div>
          <div class="terminal__body" id="term"></div>
        </div>

        <div class="stack__note">
          <span class="live-badge__dot"></span>
          <span>Живой вывод. Команда действительно запускает проект.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .stack { padding: 140px 0; }
  .stack__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }
  .stack__title { margin: 0 0 24px; }
  .stack__lead {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0 0 40px;
    max-width: 480px;
  }

  .stack__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tchip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transition: all 0.3s;
  }
  .tchip:hover {
    background: rgba(255,255,255,0.05);
    border-color: var(--tc);
    transform: translateY(-2px);
  }
  .tchip__dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--tc);
    box-shadow: 0 0 10px var(--tc);
  }
  .tchip__name {
    font-family: 'Unbounded', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
  }
  .tchip__role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted-2);
  }

  /* Terminal */
  .terminal {
    background: #0d0d0d;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.4), 0 0 0 1px rgba(212,255,60,0.08);
  }
  .terminal__bar {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background: #181818;
    border-bottom: 1px solid var(--color-border);
    gap: 16px;
  }
  .terminal__dots { display: flex; gap: 6px; }
  .terminal__dots span {
    width: 11px; height: 11px;
    border-radius: 50%;
    background: #333;
  }
  .terminal__dots span:nth-child(1) { background: #ff5f57; }
  .terminal__dots span:nth-child(2) { background: #febc2e; }
  .terminal__dots span:nth-child(3) { background: #28c840; }
  .terminal__title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--color-muted);
  }
  .terminal__body {
    padding: 24px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.75;
    color: var(--color-text);
    min-height: 420px;
    white-space: pre-wrap;
  }
  .term-line { display: block; }
  .term-prompt { color: var(--color-accent); }
  .term-command { color: var(--color-text); }
  .term-output { color: var(--color-muted); }
  .term-success { color: #28c840; }
  .term-accent { color: var(--color-accent); }
  .term-cursor {
    display: inline-block;
    width: 9px; height: 16px;
    background: var(--color-accent);
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .stack__note {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .stack { padding: 80px 0; }
    .stack__grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<script>
  const term = document.getElementById('term');
  if (!term) throw new Error('no term');

  const sequence = [
    { type: 'prompt', text: '$ ', delay: 300 },
    { type: 'command', text: 'npm create astro@latest your-site', delay: 30 },
    { type: 'newline', delay: 500 },
    { type: 'output', text: '  ✔ Where should we create your new project?', delay: 80 },
    { type: 'output', text: '  ✔ How would you like to start your new project?', delay: 200 },
    { type: 'output', text: '  ✔ Do you plan to write TypeScript?', delay: 150 },
    { type: 'newline' },
    { type: 'prompt', text: '$ ', delay: 400 },
    { type: 'command', text: 'npm run build', delay: 30 },
    { type: 'newline', delay: 400 },
    { type: 'output', text: '  01:42:15 [content] Syncing content', delay: 100 },
    { type: 'output', text: '  01:42:15 [content] Synced content', delay: 100 },
    { type: 'output', text: '  01:42:15 [build] output: "static"', delay: 100 },
    { type: 'output', text: '  01:42:15 [build] Collecting build info...', delay: 150 },
    { type: 'output', text: '  01:42:15 [vite] ✓ built in 546ms', delay: 200 },
    { type: 'success', text: '  ✓ Completed in 696ms.', delay: 150 },
    { type: 'newline' },
    { type: 'prompt', text: '$ ', delay: 400 },
    { type: 'command', text: 'git push', delay: 30 },
    { type: 'newline', delay: 400 },
    { type: 'output', text: '  Enumerating objects: 23, done.', delay: 100 },
    { type: 'output', text: '  Writing objects: 100% (23/23), 4.28 KiB', delay: 120 },
    { type: 'output', text: '  To github.com:tori2k/your-site.git', delay: 120 },
    { type: 'newline' },
    { type: 'accent', text: '  → Deployed to GitHub Pages', delay: 150 },
    { type: 'success', text: '  ✓ Lighthouse: 100 / 100 / 100 / 100', delay: 200 },
  ];

  async function typeLine(content: string, className: string) {
    const line = document.createElement('span');
    line.className = 'term-line ' + className;
    term!.appendChild(line);
    for (const char of content) {
      line.textContent += char;
      await new Promise((r) => setTimeout(r, 8 + Math.random() * 16));
    }
    term!.appendChild(document.createTextNode('\n'));
  }

  async function runSequence() {
    term!.innerHTML = '';
    for (const step of sequence) {
      await new Promise((r) => setTimeout(r, step.delay ?? 50));
      if (step.type === 'newline') {
        continue;
      }
      const cls =
        step.type === 'prompt'  ? 'term-prompt' :
        step.type === 'command' ? 'term-command' :
        step.type === 'success' ? 'term-success' :
        step.type === 'accent'  ? 'term-accent' :
                                  'term-output';
      if (step.text) await typeLine(step.text, cls);
    }
    const cursor = document.createElement('span');
    cursor.className = 'term-cursor';
    term!.appendChild(cursor);
  }

  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        runSequence();
        io.disconnect();
      }
    });
  }, { threshold: 0.3 });
  io.observe(term);
</script>
