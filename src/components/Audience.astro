---
const cases = [
  {
    num: '01',
    who: 'Я эксперт',
    goal: 'Хочу, чтобы меня находили и записывались ко мне',
    example: 'Психолог, репетитор, коуч, мастер, консультант',
    tier: 'Визитка',
    price: 'от 10 000 ₽',
  },
  {
    num: '02',
    who: 'У меня услуги или малый бизнес',
    goal: 'Нужен полноценный сайт, который находится в поиске',
    example: 'Салон, студия, агентство, частная практика',
    tier: 'Оптимум',
    price: 'от 15 000 ₽',
    featured: true,
  },
  {
    num: '03',
    who: 'У меня школа, клуб или магазин',
    goal: 'Нужны оплаты, запись, несколько страниц',
    example: 'Школа танцев, курсы, клуб, интернет-магазин',
    tier: 'Максимум',
    price: 'от 25 000 ₽',
  },
];
---
<section class="audience section-dark" id="audience">
  <div class="container-x">
    <div class="audience__head reveal">
      <div class="sec-tag">С чего начать</div>
      <h2 class="display-h">
        Какой сайт <em>вам</em><br/>
        нужен?
      </h2>
      <p class="audience__lead">
        Найдите свой случай — увидите подходящий формат и&nbsp;цену.
        Если сомневаетесь, напишите в&nbsp;Telegram — разберёмся за&nbsp;5&nbsp;минут.
      </p>
    </div>

    <div class="audience__grid">
      {cases.map((c, i) => (
        <a
          href="#pricing"
          class:list={['acard', c.featured && 'acard--featured', 'reveal']}
          style={`transition-delay: ${i * 0.08}s`}
        >
          <div class="acard__num">{c.num}</div>
          <div class="acard__who">{c.who}</div>
          <div class="acard__goal">{c.goal}</div>
          <div class="acard__example">Например: {c.example}</div>
          <div class="acard__foot">
            <div class="acard__tier">→ {c.tier}</div>
            <div class="acard__price">{c.price}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .audience { padding: 140px 0 80px; }
  .audience__head {
    max-width: 780px;
    margin-bottom: 60px;
  }
  .audience__lead {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.65;
    margin: 24px 0 0;
    max-width: 560px;
  }

  .audience__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .acard {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: all 0.4s cubic-bezier(.22,1,.36,1);
  }
  .acard:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
  }
  .acard--featured {
    background: linear-gradient(180deg, rgba(212,255,60,0.05), rgba(212,255,60,0));
    border-color: var(--color-accent);
  }

  .acard__num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--color-accent);
  }
  .acard__who {
    font-family: 'Unbounded', sans-serif;
    font-size: 20px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .acard__goal {
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-muted);
  }
  .acard__example {
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-muted-2);
    flex: 1;
  }
  .acard__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 18px;
    border-top: 1px solid var(--color-border);
  }
  .acard__tier {
    font-family: 'Unbounded', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }
  .acard__price {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .audience { padding: 80px 0 40px; }
    .audience__grid { grid-template-columns: 1fr; }
  }
</style>
