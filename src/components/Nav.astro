---
const base = import.meta.env.BASE_URL;
const items = [
  { href: '#work', label: 'Работы' },
  { href: '#stack', label: 'Стек' },
  { href: '#pricing', label: 'Цены' },
  { href: `${base}/blog/`, label: 'Блог' },
  { href: '#faq', label: 'FAQ' },
];
---
<nav class="nav">
  <div class="container-x nav__inner">
    <a href="#" class="nav__logo">
      <span class="nav__logo-symbol">◐</span>
      <span class="nav__logo-text">
        Кирилл<span class="nav__logo-accent">.</span>
      </span>
    </a>

    <ul class="nav__links">
      {items.map((i) => <li><a href={i.href}>{i.label}</a></li>)}
    </ul>

    <div class="nav__right">
      <span class="live-badge">
        <span class="live-badge__dot"></span>
        доступен
      </span>
      <a href="https://t.me/tori2k" target="_blank" rel="noopener" class="nav__cta">
        <span class="btn__plus">(+)</span>
        Написать
      </a>
    </div>

    <button class="nav__burger" id="navBurger" aria-label="Меню">
      <span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="navMobile">
    {items.map((i) => <a href={i.href}>{i.label}</a>)}
    <a href="https://t.me/tori2k" target="_blank" rel="noopener" class="nav__cta">
      <span class="btn__plus">(+)</span>
      Написать в Telegram
    </a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    backdrop-filter: blur(20px);
    background: rgba(10,10,10,0.7);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    gap: 24px;
  }
  .nav__logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
    font-family: 'Unbounded', sans-serif;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .nav__logo-symbol {
    color: var(--color-accent);
    font-size: 22px;
    line-height: 1;
  }
  .nav__logo-accent { color: var(--color-accent); }

  .nav__links {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__links a {
    font-family: 'Unbounded', sans-serif;
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #d0d0d0;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav__links a:hover { color: var(--color-accent); }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    font-family: 'Unbounded', sans-serif;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
    border-radius: 999px;
    transition: all 0.25s;
  }
  .nav__cta:hover {
    background: var(--color-accent);
    color: #0a0a0a;
  }
  .nav__cta .btn__plus { font-size: 14px; }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: transparent;
    border: 0;
    cursor: none;
    padding: 8px;
  }
  .nav__burger span {
    display: block;
    width: 22px; height: 1.5px;
    background: var(--color-text);
  }

  .nav__mobile {
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: rgba(10,10,10,0.98);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    flex-direction: column;
    padding: 20px 24px 28px;
    gap: 8px;
    display: none;
  }
  .nav__mobile.open { display: flex; }
  .nav__mobile a {
    font-family: 'Unbounded', sans-serif;
    font-size: 14px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #d0d0d0;
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav__mobile .nav__cta {
    margin-top: 12px;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .nav__links, .nav__right { display: none; }
    .nav__burger { display: flex; }
  }
</style>

<script>
  const burger = document.getElementById('navBurger');
  const mobile = document.getElementById('navMobile');
  burger?.addEventListener('click', () => mobile?.classList.toggle('open'));
  mobile?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => mobile.classList.remove('open')));
</script>
