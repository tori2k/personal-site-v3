---
const tiers = [
  {
    name: 'Визитка',
    tag: 'Для экспертов',
    price: '10 000 ₽',
    time: '1–2 дня',
    desc: 'Одна страница: о вас, услуги, отзывы, контакты. Нужно, чтобы клиенты находили и оставляли заявки.',
    includes: [
      'Удобно открывается на телефоне',
      'Заявки приходят в Telegram',
      'Свой домен (например, ваше-имя.ru)',
      'Правки в течение недели',
    ],
  },
  {
    name: 'Оптимум',
    tag: 'Для малого бизнеса',
    price: '15 000 ₽',
    time: '2–4 дня',
    desc: 'Если уже есть клиенты и нужен полноценный сайт, который выглядит солидно и находится в поиске.',
    includes: [
      'Всё из «Визитки»',
      'Больше секций: цены, кейсы, FAQ',
      'Сайт появится в Яндексе и Google',
      'Статистика посещений',
      'Заявки собираются в одну таблицу',
    ],
    featured: true,
  },
  {
    name: 'Максимум',
    tag: 'Для школ и сервисов',
    price: 'от 25 000 ₽',
    time: '1–3 недели',
    desc: 'Для школ, клубов, магазинов: несколько страниц, приём оплат, запись на услуги, управление контентом.',
    includes: [
      'Всё из «Оптимума»',
      'Несколько страниц с разным содержимым',
      'Вы сами меняете тексты и цены — без программиста',
      'Приём оплат картой онлайн',
      'Продажа билетов на мероприятия',
      'Другие интеграции под ваши задачи',
    ],
  },
];
---
<section class="pricing section-dark" id="pricing">
  <div class="container-x">
    <div class="pricing__head reveal">
      <div class="sec-tag">Цены</div>
      <h2 class="display-h">
        Три <em>формата</em>.<br/>
        Выберите свой.
      </h2>
      <p class="pricing__lead">
        Цена и срок фиксируются до начала работы. Срочно — +30% к сроку в 1 день.
        Несрочно — −20% со сдвигом сроков.
      </p>
    </div>

    <div class="pricing__grid">
      {tiers.map((t, i) => (
        <article class:list={['tier', t.featured && 'tier--featured', 'reveal']} style={`transition-delay: ${i * 0.1}s`}>
          <div class="tier__head">
            <div class="tier__name">{t.name}</div>
            <div class="tier__tag">{t.tag}</div>
          </div>
          <div class="tier__price-row">
            <div class="tier__price">{t.price}</div>
            <div class="tier__time">{t.time}</div>
          </div>
          <p class="tier__desc">{t.desc}</p>
          <ul class="tier__includes">
            {t.includes.map((inc) => (
              <li>
                <span class="tier__check">(+)</span>
                {inc}
              </li>
            ))}
          </ul>
          <a href="https://t.me/tori2k" target="_blank" rel="noopener" class="btn tier__cta">
            <span class="btn__plus">(+)</span>
            Обсудить
          </a>
        </article>
      ))}
    </div>

    <div class="pricing__note reveal">
      <span>⊕</span>
      Не уверены, какой формат подходит? Напишите —
      <a href="https://t.me/tori2k" target="_blank" rel="noopener">подскажу за 5 минут</a>.
    </div>
  </div>
</section>

<style>
  .pricing { padding: 140px 0; }
  .pricing__head {
    max-width: 780px;
    margin-bottom: 60px;
  }
  .pricing__lead {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.65;
    margin: 24px 0 0;
    max-width: 520px;
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .tier {
    padding: 36px 30px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    transition: all 0.4s cubic-bezier(.22,1,.36,1);
  }
  .tier:hover {
    border-color: var(--color-accent);
    transform: translateY(-6px);
  }
  .tier--featured {
    background: linear-gradient(180deg, rgba(212,255,60,0.05), rgba(212,255,60,0));
    border-color: var(--color-accent);
    box-shadow: 0 30px 60px rgba(212,255,60,0.12);
  }

  .tier__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--color-border);
  }
  .tier__name {
    font-family: 'Unbounded', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .tier__tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--color-muted);
  }

  .tier__price-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 16px;
  }
  .tier__price {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .tier__time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .tier__desc {
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0 0 24px;
  }
  .tier__includes {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tier__includes li {
    display: flex;
    gap: 10px;
    font-size: 13.5px;
    color: #d0d0d0;
    line-height: 1.5;
  }
  .tier__check {
    color: var(--color-accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    flex-shrink: 0;
  }

  .tier__cta { align-self: flex-start; }

  .pricing__note {
    text-align: center;
    margin-top: 50px;
    font-size: 14px;
    color: var(--color-muted);
  }
  .pricing__note span {
    color: var(--color-accent);
    margin-right: 6px;
  }
  .pricing__note a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  @media (max-width: 900px) {
    .pricing { padding: 80px 0; }
    .pricing__grid { grid-template-columns: 1fr; }
  }
</style>
