---
const base = import.meta.env.BASE_URL;

const cases = [
  {
    slug: 'manifik',
    img: 'manifik.jpg',
    title: 'Manifik',
    niche: 'Школа вокала',
    tags: ['Флагман', 'Premium', '10 секций'],
    url: 'https://manifik-school.ru',
    featured: true,
    status: 'В продакшене · домен свой',
    size: 'hero',
  },
  {
    slug: 'nails',
    img: 'nails.jpg',
    title: 'Эстетика рук',
    niche: 'Beauty · маникюр',
    tags: ['Beauty', 'Галерея'],
    url: 'https://kb-nails.surge.sh',
    size: 'tall',
  },
  {
    slug: 'cosmetologist',
    img: 'cosmetologist.jpg',
    title: 'Премиум эстетика',
    niche: 'Косметолог',
    tags: ['Lifestyle', 'Premium'],
    url: 'https://kb-cosmetologist.surge.sh',
    size: 'wide',
  },
  {
    slug: 'psychologist',
    img: 'psychologist.jpg',
    title: 'Пространство доверия',
    niche: 'Психолог',
    tags: ['Serif', 'Экспертность'],
    url: 'https://kb-psychologist.surge.sh',
    size: 'square',
  },
  {
    slug: 'tutor',
    img: 'tutor.jpg',
    title: 'Школа результатов',
    niche: 'Репетитор',
    tags: ['Bold', 'Dark'],
    url: 'https://kb-tutor.surge.sh',
    size: 'square',
  },
  {
    slug: 'silverstandard',
    img: 'silverstandard.jpg',
    title: 'Серебряный Стандарт',
    niche: 'B2B · услуги',
    tags: ['B2B', 'Dark'],
    url: 'https://kb-silverstandard.surge.sh',
    size: 'wide',
  },
  {
    slug: 'fleshka',
    img: 'fleshka.jpg',
    title: 'FLESHKA',
    niche: 'Продукт',
    tags: ['E-com', 'Brand'],
    url: 'https://kb-fleshka.surge.sh',
    size: 'tall',
  },
  {
    slug: 'vaultkey',
    img: 'vaultkey.jpg',
    title: 'VAULTKEY',
    niche: 'Крипто-кошелёк',
    tags: ['Crypto', 'Tech', 'Dark'],
    url: 'https://kb-vaultkey.surge.sh',
    size: 'square',
  },
];
---
<section class="work section-dark" id="work">
  <div class="container-x">
    <div class="work__head reveal">
      <div class="sec-tag">Портфолио · 8 кейсов</div>
      <h2 class="display-h work__title">
        Реальные <em>проекты.</em><br/>
        Живые ссылки.
      </h2>
      <p class="work__lead">
        Каждый проект — в продакшене. Клик по карточке открывает живой сайт.
        Скриншоты сделаны автоматически и обновляются при деплое.
      </p>
    </div>

    <div class="bento">
      {cases.map((c, i) => (
        <a
          href={c.url}
          target="_blank"
          rel="noopener"
          class:list={['bcard', `bcard--${c.size}`, c.featured && 'bcard--featured']}
          style={`--i: ${i}`}
          data-hover
        >
          <div class="bcard__img">
            <img
              src={`${base}screenshots/${c.img}`}
              alt={c.title}
              loading={i < 3 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </div>
          <div class="bcard__overlay">
            <div class="bcard__top">
              <span class="bcard__niche">{c.niche}</span>
              {c.status && <span class="bcard__status">{c.status}</span>}
            </div>
            <div class="bcard__bottom">
              <h3 class="bcard__title">{c.title}</h3>
              <div class="bcard__tags">
                {c.tags.map((t) => <span class="bcard__tag">{t}</span>)}
              </div>
              <div class="bcard__cta">
                <span>открыть живой сайт</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M8 7h9v9"/></svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .work {
    padding: 140px 0;
    position: relative;
  }
  .work__head {
    max-width: 860px;
    margin-bottom: 60px;
  }
  .work__title { margin: 0 0 24px; }
  .work__lead {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 540px;
  }

  /* Bento grid */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 14px;
  }

  .bcard {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.5s cubic-bezier(.22,1,.36,1);
    border-radius: 2px;
    animation: bcard-in 0.9s cubic-bezier(.22,1,.36,1) backwards;
    animation-delay: calc(var(--i) * 0.08s);
  }
  @keyframes bcard-in {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .bcard--hero { grid-column: span 2; grid-row: span 2; }
  .bcard--wide { grid-column: span 2; }
  .bcard--tall { grid-row: span 2; }
  .bcard--square { grid-column: span 1; }

  .bcard:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: 0 30px 60px rgba(212,255,60,0.1);
  }

  .bcard__img {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .bcard__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.7s cubic-bezier(.22,1,.36,1);
    filter: grayscale(0.3) brightness(0.75);
  }
  .bcard:hover .bcard__img img {
    transform: scale(1.05);
    filter: grayscale(0) brightness(1);
  }

  .bcard__overlay {
    position: absolute;
    inset: 0;
    padding: 22px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: linear-gradient(180deg, rgba(10,10,10,0.4) 0%, rgba(10,10,10,0.1) 40%, rgba(10,10,10,0.95) 100%);
    transition: background 0.4s;
  }
  .bcard:hover .bcard__overlay {
    background: linear-gradient(180deg, rgba(10,10,10,0.15) 0%, rgba(10,10,10,0.05) 40%, rgba(10,10,10,0.92) 100%);
  }

  .bcard__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }
  .bcard__niche {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-accent);
    padding: 4px 10px;
    background: rgba(212,255,60,0.1);
    border: 1px solid rgba(212,255,60,0.3);
    border-radius: 999px;
  }
  .bcard__status {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: rgba(255,255,255,0.7);
    letter-spacing: 1px;
    text-align: right;
    max-width: 140px;
    line-height: 1.3;
  }

  .bcard__title {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(20px, 2vw, 28px);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
    color: #fff;
  }
  .bcard--hero .bcard__title { font-size: clamp(28px, 3vw, 44px); }

  .bcard__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .bcard__tag {
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    padding: 3px 8px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
  }

  .bcard__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-accent);
    transition: gap 0.25s;
  }
  .bcard:hover .bcard__cta { gap: 14px; }

  @media (max-width: 1000px) {
    .bento { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; }
    .bcard--hero { grid-column: span 2; grid-row: span 2; }
    .bcard--wide { grid-column: span 2; grid-row: span 1; }
    .bcard--tall { grid-column: span 1; grid-row: span 2; }
  }
  @media (max-width: 600px) {
    .bento { grid-template-columns: 1fr; grid-auto-rows: 240px; }
    .bcard--hero, .bcard--wide, .bcard--tall, .bcard--square {
      grid-column: span 1; grid-row: span 1;
    }
    .bcard--hero { grid-row: span 2; }
    .work { padding: 80px 0; }
  }
</style>
