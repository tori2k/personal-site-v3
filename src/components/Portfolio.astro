---
const base = import.meta.env.BASE_URL;

const featured = [
  {
    slug: 'manifik',
    img: 'manifik.jpg',
    title: 'Manifik',
    niche: 'Школа вокала',
    url: 'https://manifik-school.ru',
    status: 'В продакшене',
    lede: 'Школе нужен был сайт, через который родители находят педагогов, записываются на занятия и сразу оплачивают их онлайн.',
    points: [
      'Многостраничный сайт с каталогом педагогов и направлений',
      'Онлайн-оплата занятий и абонементов',
      'Запись на пробный урок — заявка приходит в Telegram',
      'Администратор сам редактирует цены и расписание',
    ],
  },
  {
    slug: 'znamya-truda',
    img: 'znamya-truda.jpg',
    title: 'ФК «Знамя Труда»',
    niche: 'Футбольный клуб · Орехово-Зуево',
    url: 'https://tori2k.github.io/znamya-truda-draft/',
    status: 'В работе',
    lede: 'Старейший действующий футбольный клуб России (основан в 1909). Нужен официальный сайт с матчами, новостями, историей и продажей абонементов.',
    points: [
      'Расписание матчей и результаты',
      'История клуба и состав команды',
      'Продажа абонементов и билетов',
      'Лента новостей, партнёры, контакты',
    ],
  },
];

const others = [
  {
    slug: 'cosmetologist',
    img: 'cosmetologist.jpg',
    title: 'Премиум эстетика',
    niche: 'Косметолог',
    url: 'https://kb-cosmetologist.surge.sh',
  },
  {
    slug: 'psychologist',
    img: 'psychologist.jpg',
    title: 'Пространство доверия',
    niche: 'Психолог',
    url: 'https://kb-psychologist.surge.sh',
  },
  {
    slug: 'tutor',
    img: 'tutor.jpg',
    title: 'Школа результатов',
    niche: 'Репетитор',
    url: 'https://kb-tutor.surge.sh',
  },
  {
    slug: 'nails',
    img: 'nails.jpg',
    title: 'Эстетика рук',
    niche: 'Маникюр',
    url: 'https://kb-nails.surge.sh',
  },
  {
    slug: 'silverstandard',
    img: 'silverstandard.jpg',
    title: 'Серебряный Стандарт',
    niche: 'B2B · услуги',
    url: 'https://kb-silverstandard.surge.sh',
  },
  {
    slug: 'fleshka',
    img: 'fleshka.jpg',
    title: 'FLESHKA',
    niche: 'Продукт',
    url: 'https://kb-fleshka.surge.sh',
  },
  {
    slug: 'vaultkey',
    img: 'vaultkey.jpg',
    title: 'VAULTKEY',
    niche: 'Крипто-кошелёк',
    url: 'https://kb-vaultkey.surge.sh',
  },
];
---
<section class="work section-dark" id="work">
  <div class="container-x">
    <div class="work__head reveal">
      <div class="sec-tag">Портфолио</div>
      <h2 class="display-h work__title">
        Главные <em>проекты</em>
      </h2>
      <p class="work__lead">
        Два флагмана — разобранно и&nbsp;подробно. Ниже — ещё семь работ, которые можно открыть и&nbsp;посмотреть вживую.
      </p>
    </div>

    <div class="featured">
      {featured.map((f, i) => (
        <article class:list={['fcard', 'reveal']} style={`transition-delay: ${i * 0.1}s`}>
          <a href={f.url} target="_blank" rel="noopener" class="fcard__media">
            <img
              src={`${base}screenshots/${f.img}`}
              alt={f.title}
              loading="eager"
              decoding="async"
            />
            <span class="fcard__status">{f.status}</span>
          </a>
          <div class="fcard__body">
            <div class="fcard__niche">{f.niche}</div>
            <h3 class="fcard__title">{f.title}</h3>
            <p class="fcard__lede">{f.lede}</p>
            <ul class="fcard__points">
              {f.points.map((p) => (
                <li>
                  <span class="fcard__check">(+)</span>
                  {p}
                </li>
              ))}
            </ul>
            <a href={f.url} target="_blank" rel="noopener" class="btn btn--filled fcard__cta">
              <span class="btn__plus">(+)</span>
              Открыть сайт
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Diptych: concept piece -->
    <article class="diptych reveal">
      <div class="diptych__head">
        <div class="diptych__tag">Концепт · спекулятивная работа</div>
        <h3 class="diptych__title">
          Собрал концепт сайта для&nbsp;<em>ЧТИВО ДОМА</em>
        </h3>
        <p class="diptych__lede">
          В&nbsp;апреле был в&nbsp;ЧТИВО ДОМЕ у&nbsp;Сергея Минаева. Место попало&nbsp;в, вдохновился — собрал сайт-визитку в&nbsp;их&nbsp;фирменной стилистике. Это не&nbsp;заказ и&nbsp;не&nbsp;предложение, просто упражнение в&nbsp;рамках места, которое понравилось.
        </p>
      </div>

      <div class="diptych__media">
        <div class="diptych__half diptych__half--photo">
          <img src={`${base}screenshots/chtivo-minaev.jpg`} alt="Кирилл Барыев с Сергеем Минаевым в ЧТИВО ДОМЕ" loading="lazy" decoding="async" />
          <span class="diptych__label diptych__label--left">Кинозал · 18.04.2026</span>
        </div>
        <a href="https://tori2k.github.io/chtivo-dom-concept/" target="_blank" rel="noopener" class="diptych__half diptych__half--site">
          <img src={`${base}screenshots/chtivo-dom.jpg`} alt="Скриншот концепт-сайта ЧТИВО ДОМ" loading="lazy" decoding="async" />
          <span class="diptych__label diptych__label--right">Концепт-сайт</span>
          <span class="diptych__open">
            Открыть концепт
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M8 7h9v9"/></svg>
          </span>
        </a>
      </div>
    </article>

    <div class="others-head reveal">
      <div class="sec-tag others-tag">Примеры других работ</div>
      <p class="others-lead">
        Разные ниши и&nbsp;форматы — чтобы показать, как может выглядеть сайт в&nbsp;вашей сфере.
      </p>
    </div>

    <div class="others">
      {others.map((o, i) => (
        <a
          href={o.url}
          target="_blank"
          rel="noopener"
          class="ocard reveal"
          style={`transition-delay: ${i * 0.05}s`}
        >
          <div class="ocard__img">
            <img
              src={`${base}screenshots/${o.img}`}
              alt={o.title}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="ocard__meta">
            <div class="ocard__text">
              <div class="ocard__niche">{o.niche}</div>
              <div class="ocard__title">{o.title}</div>
            </div>
            <svg class="ocard__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M8 7h9v9"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .work { padding: 140px 0; }
  .work__head {
    max-width: 860px;
    margin-bottom: 60px;
  }
  .work__title { margin: 0 0 24px; }
  .work__lead {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 560px;
  }

  /* Featured — два флагмана */
  .featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 100px;
  }
  .fcard {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.4s;
  }
  .fcard:hover { border-color: var(--color-accent); }

  .fcard__media {
    position: relative;
    overflow: hidden;
    min-height: 380px;
    display: block;
  }
  .fcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.7s cubic-bezier(.22,1,.36,1);
  }
  .fcard:hover .fcard__media img { transform: scale(1.03); }

  .fcard__status {
    position: absolute;
    top: 20px;
    left: 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text);
    padding: 6px 12px;
    background: rgba(242,239,231,0.92);
    border: 1px solid rgba(17,17,17,0.15);
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }

  .fcard__body {
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
  }
  .fcard__niche {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 14px;
  }
  .fcard__title {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(28px, 2.8vw, 40px);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 18px;
    color: var(--color-text);
  }
  .fcard__lede {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0 0 24px;
  }
  .fcard__points {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .fcard__points li {
    display: flex;
    gap: 10px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-text);
  }
  .fcard__check {
    color: var(--color-accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    flex-shrink: 0;
  }
  .fcard__cta { align-self: flex-start; margin-top: auto; }

  /* Diptych — концепт-кейс с фото и скриншотом */
  .diptych {
    margin: 0 0 100px;
    padding-top: 60px;
    border-top: 1px solid var(--color-border);
  }
  .diptych__head {
    max-width: 780px;
    margin-bottom: 40px;
  }
  .diptych__tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 18px;
  }
  .diptych__title {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(26px, 3vw, 44px);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
    color: var(--color-text);
  }
  .diptych__title em {
    font-style: italic;
    color: var(--color-muted);
    font-weight: 300;
  }
  .diptych__lede {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-muted);
    margin: 0;
    max-width: 640px;
  }

  .diptych__media {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 16px;
  }
  .diptych__half {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-surface);
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .diptych__half img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 1s cubic-bezier(.22,1,.36,1);
  }
  .diptych__half--site {
    aspect-ratio: auto;
    min-height: 100%;
  }
  .diptych__half--site img {
    object-position: top center;
  }
  .diptych__half--site:hover img { transform: scale(1.03); }

  .diptych__label {
    position: absolute;
    top: 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 12px;
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: 999px;
  }
  .diptych__label--left { left: 18px; }
  .diptych__label--right {
    left: 18px;
    background: #A22E1F;
    color: #f5f1e8;
  }
  .diptych__open {
    position: absolute;
    bottom: 18px;
    right: 18px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: 999px;
    transition: gap 0.3s, background 0.3s;
  }
  .diptych__half--site:hover .diptych__open {
    background: var(--color-text);
    color: var(--color-bg);
    gap: 12px;
  }

  @media (max-width: 900px) {
    .diptych__media { grid-template-columns: 1fr; }
    .diptych__half, .diptych__half--site {
      aspect-ratio: 4/5;
      min-height: auto;
    }
  }

  /* Others — компактная сетка */
  .others-head {
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .others-tag { color: var(--color-muted); }
  .others-tag::before { background: var(--color-muted) !important; }
  .others-lead {
    font-size: 14px;
    color: var(--color-muted-2);
    margin: 0;
    max-width: 480px;
  }

  .others {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  .ocard {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.4s cubic-bezier(.22,1,.36,1);
  }
  .ocard:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
  }
  .ocard__img {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #0f0f0f;
  }
  .ocard__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.6s cubic-bezier(.22,1,.36,1);
  }
  .ocard:hover .ocard__img img { transform: scale(1.06); }
  .ocard__meta {
    padding: 16px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .ocard__niche {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted-2);
    margin-bottom: 4px;
  }
  .ocard__title {
    font-family: 'Unbounded', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .ocard__arrow {
    color: var(--color-muted-2);
    flex-shrink: 0;
    transition: color 0.3s, transform 0.3s;
  }
  .ocard:hover .ocard__arrow {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }

  @media (max-width: 1000px) {
    .fcard { grid-template-columns: 1fr; }
    .fcard__media { min-height: 260px; }
    .others { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .work { padding: 80px 0; }
    .fcard__body { padding: 28px 22px; }
    .others { grid-template-columns: 1fr; }
    .featured { margin-bottom: 60px; }
  }
</style>
